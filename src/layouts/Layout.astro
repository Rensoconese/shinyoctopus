---
import { SEO } from "astro-seo";
import TopNav from "../components/TopNav.astro";
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
  image?: string;
  type?: string;
  canonical?: string;
  schema?: Record<string, unknown> | Record<string, unknown>[];
  noindex?: boolean;
}

const {
  title = "Shiny Octopus | SEO & Accessibility Audits | Design & Development Studio",
  description = "We help businesses grow with SEO audits, accessibility audits, and custom web development. Clear action plans, measurable results, and websites that actually convert.",
  image = "/images/og-image.jpg", // Make sure to create this image
  type = "website",
  canonical = Astro.url.href,
  schema,
  noindex = false
} = Astro.props;

// Base URL for absolute paths
const siteUrl = "https://shinyoctopus.studio";

// Build absolute image URL if not already a complete URL
const ogImage = image.startsWith('http') ? image : `${siteUrl}${image}`;

// Organization schema — global, always present
const organizationSchema = {
  "@context": "https://schema.org",
  "@type": "Organization",
  "name": "Shiny Octopus",
  "url": siteUrl,
  "logo": `${siteUrl}/images/og-image.jpg`,
  "description": "Digital creative studio specialized in SEO audits, accessibility audits, and web development that drives business growth.",
  "email": "hi@shinyoctopus.studio",
  "sameAs": [
    "https://x.com/shinyoctopus"
  ],
  "knowsAbout": ["SEO", "Web Accessibility", "Web Development", "UI/UX Design", "Digital Strategy"]
};

// BreadcrumbList schema — auto-generated from URL
const pathSegments = new URL(canonical).pathname.split('/').filter(Boolean);
const breadcrumbNames: Record<string, string> = {
  "seo": "SEO Audit",
  "accesibilidad": "Accessibility Audit",
  "servidores": "Platform Strategy",
  "blog": "Blog",
  "contact": "Contact",
  "about": "About",
  "privacy": "Privacy Policy",
};
const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {
      "@type": "ListItem",
      "position": 1,
      "name": "Home",
      "item": siteUrl
    },
    ...pathSegments.map((segment, i) => ({
      "@type": "ListItem",
      "position": i + 2,
      "name": breadcrumbNames[segment] || segment.charAt(0).toUpperCase() + segment.slice(1).replace(/-/g, ' '),
      "item": `${siteUrl}/${pathSegments.slice(0, i + 1).join('/')}`
    }))
  ]
};

// Combine all schemas
const allSchemas = [
  organizationSchema,
  ...(pathSegments.length > 0 ? [breadcrumbSchema] : []),
  ...(schema ? (Array.isArray(schema) ? schema : [schema]) : [])
];
---

<!DOCTYPE html>
<html lang="en" prefix="og: https://ogp.me/ns#">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" sizes="32x32" href="/images/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/images/favicon-16x16.png" />
    <meta name="generator" content={Astro.generator} />
    {noindex && <meta name="robots" content="noindex" />}

    <!-- Precargar fuentes críticas para mejorar el rendimiento -->
    <link rel="preload" href="/fonts/PPNeueMontreal-Medium.woff2" as="font" type="font/woff2" crossorigin>
    <link rel="preload" href="/fonts/PPNeueMontreal-Bold.woff2" as="font" type="font/woff2" crossorigin>
    <link rel="preload" href="/fonts/PPHatton-Ultralight.woff2" as="font" type="font/woff2" crossorigin>
    
    <SEO
      title={title}
      description={description}
      canonical={canonical}
      openGraph={{
        basic: {
          title: title,
          type: type,
          image: ogImage,
          url: canonical,
        },
        optional: {
          description: description,
          locale: "en_US",
          siteName: "Shiny Octopus",
        },
        image: {
          alt: `${title} - Shiny Octopus`,
        },
      }}
      twitter={{
        card: "summary_large_image",
        site: "@shinyoctopus",
        creator: "@shinyoctopus",
        title: title,
        description: description,
        image: ogImage,
        imageAlt: `${title} - Shiny Octopus`,
      }}
      extend={{
        meta: [
          { name: "theme-color", content: "#000000" },
          { name: "apple-mobile-web-app-capable", content: "yes" },
          { name: "mobile-web-app-capable", content: "yes" },
          { name: "apple-mobile-web-app-status-bar-style", content: "black" },
        ],
        link: [
          { rel: "manifest", href: "/manifest.json" },
          { rel: "apple-touch-icon", href: "/apple-touch-icon.png" },
        ],
      }}
    />

    {allSchemas.map(s => (
      <script type="application/ld+json" set:html={JSON.stringify(s)} />
    ))}
  </head>
  <body>
    <a href="#main-content" class="skip-link">Skip to content</a>
    <TopNav />
    <slot />
    <footer class="site-footer">
      <p>&copy; 2026 Shiny Octopus. All rights reserved.</p>
      <a href="/privacy">Privacy Policy</a>
    </footer>
  </body>
</html>

<style is:global>
  .skip-link {
    position: absolute;
    top: -100%;
    left: 1rem;
    background: #000;
    color: #fff;
    padding: 0.75rem 1.5rem;
    z-index: 9999;
    text-decoration: none;
    font-family: var(--font-primary);
    font-size: 0.9rem;
    border: 1px solid rgba(255, 255, 255, 0.3);
    border-radius: 0.25rem;
  }

  .skip-link:focus {
    top: 0;
  }
  .site-footer {
    text-align: center;
    font-size: 0.85rem;
    color: rgba(255, 255, 255, 0.5);
    padding: 2rem 1rem;
    border-top: 1px solid rgba(255, 255, 255, 0.08);
  }

  .site-footer a {
    color: rgba(255, 255, 255, 0.5);
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .site-footer a:hover {
    color: rgba(255, 255, 255, 0.8);
  }

  .site-footer p {
    margin-bottom: 0.5rem;
  }
</style>
