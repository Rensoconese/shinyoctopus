---
import Layout from "../layouts/Layout.astro";
import Logo from "../components/Logo.astro";
---

<Layout title="Page not found" noindex>
  <main id="main-content" class="not-found">
    <div class="not-found__logo">
      <Logo />
    </div>
    <h1 class="not-found__heading">404</h1>
    <p class="not-found__message">The page you're looking for doesn't exist or has been moved.</p>
    <a href="/" class="not-found__cta">Back to home</a>
  </main>
</Layout>

<style>
  .not-found {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    min-height: 80vh;
    padding: 2rem 1rem;
    text-align: center;
  }

  .not-found__logo {
    margin-bottom: 2.5rem;
  }

  .not-found__heading {
    font-family: var(--font-titles);
    font-size: clamp(6rem, 18vw, 12rem);
    font-weight: 100;
    line-height: 1;
    text-transform: uppercase;
    margin-bottom: 1rem;
    color: #fff;
  }

  .not-found__message {
    font-family: var(--font-primary);
    font-size: clamp(1rem, 2vw, 1.25rem);
    color: rgba(255, 255, 255, 0.75);
    line-height: 1.6;
    max-width: 32rem;
    margin-bottom: 2.5rem;
  }

  .not-found__cta {
    display: inline-block;
    background-color: white;
    color: black;
    border: 1px solid rgb(255, 255, 255);
    border-radius: 1.5rem;
    padding: 1rem 1.2rem;
    font-size: 1.2rem;
    text-decoration: none;
    cursor: pointer;
    transition:
      background-color 0.3s ease,
      border-color 0.3s ease,
      transform 0.3s ease,
      box-shadow 0.3s ease;
  }

  .not-found__cta:hover {
    background-color: black;
    color: white;
    border-color: rgba(255, 255, 255, 0.5);
    transform: translateY(-5px);
    box-shadow:
      0 0 10px #fff,
      0 0 20px #88d8ff,
      0 0 30px #88d8ff,
      0 0 40px #1e90ff,
      0 0 70px #1e90ff,
      0 0 80px #0066cc,
      0 0 100px #003399,
      0 0 150px #000066;
  }

  .not-found__cta:active {
    background-color: #555;
  }
</style>
