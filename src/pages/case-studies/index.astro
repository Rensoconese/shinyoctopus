---
import Layout from "../../layouts/Layout.astro";

const pageTitle = "Case Studies | Shiny Octopus";
const pageDescription =
  "Explore how Shiny Octopus designs and builds websites that improve positioning, trust, and conversion.";

const caseStudies = [
  {
    slug: "beemyhost",
    name: "BeeMyHost",
    category: "Short-term rental property management / Airbnb management",
    result: "10,000+ pageviews reached",
    summary:
      "A conversion-focused website that helped reposition BeeMyHost as a trusted property management partner for owners evaluating their next move.",
    websiteUrl: "https://beemyhost.com.ar",
  },
];

const collectionSchema = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "name": pageTitle,
  "description": pageDescription,
  "url": "https://shinyoctopus.studio/case-studies/",
};
---

<Layout title={pageTitle} description={pageDescription} schema={collectionSchema}>
  <main id="main-content" class="content-page">
    <header class="page-header">
      <h1>Real businesses, real results</h1>
      <p>
        We design and build websites that improve positioning, trust, and
        conversion. Here are the stories behind some of the work.
      </p>
    </header>

    <section class="cases-list" aria-label="Case studies">
      {caseStudies.map((study) => (
        <a href={`/case-studies/${study.slug}/`} class="case-card">
          <article>
            <h2 class="case-card-name">{study.name}</h2>
            <p class="case-card-category">{study.category}</p>
            <p class="case-card-summary">{study.summary}</p>
            <p class="case-card-result">{study.result}</p>
          </article>
        </a>
      ))}
    </section>

    <section class="closing">
      <h2>Have a project like this?</h2>
      <p>
        We work with founders and teams who care about how their website
        performs in the real world. Tell us what you are building.
      </p>
      <a href="/contact" class="closing-cta">Let's talk</a>
    </section>
  </main>
</Layout>

<style>
  .content-page {
    display: grid;
    grid-template-columns: repeat(12, 1fr);
    column-gap: 1.5rem;
    padding: 6.5rem 2rem 4rem;
  }

  .page-header {
    grid-column: 4 / 10;
    margin-bottom: 4rem;
    padding-bottom: 3rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.12);
  }

  .kicker {
    text-transform: uppercase;
    letter-spacing: 0.14em;
    font-size: 0.78rem;
    color: rgba(255, 255, 255, 0.5);
    margin-bottom: 0.6rem;
  }

  h1 {
    font-family: var(--font-titles);
    font-size: clamp(2.4rem, 7vw, 4.5rem);
    line-height: 0.95;
    font-weight: 300;
    text-transform: uppercase;
    margin-bottom: 1.5rem;
    max-width: 50rem;
  }

  .page-header > p:last-child {
    font-size: 1rem;
    color: rgba(255, 255, 255, 0.75);
    max-width: 40rem;
    line-height: 1.6;
  }

  .cases-list {
    grid-column: 4 / 10;
    display: grid;
    gap: 1.5rem;
  }

  .case-card {
    display: block;
    text-decoration: none;
    color: inherit;
    padding: 2rem;
    border: 1px solid rgba(255, 255, 255, 0.12);
    border-radius: 1rem;
    background: rgba(255, 255, 255, 0.02);
    transition: border-color 0.2s ease, background 0.2s ease;
  }

  .case-card article {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }

  .case-card:hover,
  .case-card:focus-visible {
    border-color: rgba(255, 255, 255, 0.34);
    background: rgba(255, 255, 255, 0.06);
    outline: none;
  }

  .case-card-category {
    text-transform: uppercase;
    letter-spacing: 0.12em;
    font-size: 0.72rem;
    color: rgba(255, 255, 255, 0.45);
  }

  .case-card-name {
    font-family: var(--font-titles);
    font-weight: 100;
    text-transform: uppercase;
    line-height: 0.95;
    font-size: clamp(2rem, 5vw, 3.25rem);
    letter-spacing: -0.01em;
  }

  .case-card-summary {
    color: rgba(255, 255, 255, 0.78);
    line-height: 1.55;
    font-size: 1rem;
    margin-top: 0.4rem;
    margin-bottom: 0.4rem;
  }

  .case-card-result {
    font-size: 0.8rem;
    color: rgba(136, 216, 255, 0.85);
    letter-spacing: 0.04em;
  }

  .closing {
    grid-column: 4 / 10;
    margin-top: 5rem;
    padding: 4rem 1.5rem;
    border-top: 1px solid rgba(255, 255, 255, 0.12);
    text-align: center;
  }

  .closing h2 {
    font-family: var(--font-titles);
    font-weight: 100;
    text-transform: uppercase;
    font-size: clamp(1.8rem, 4vw, 2.75rem);
    line-height: 1;
    margin-bottom: 1rem;
  }

  .closing p {
    color: rgba(255, 255, 255, 0.7);
    max-width: 32rem;
    margin: 0 auto 2rem;
    line-height: 1.55;
  }

  .closing-cta {
    display: inline-block;
    background: #fff;
    color: #000;
    text-decoration: none;
    padding: 1rem 1.6rem;
    border-radius: 999px;
    font-weight: 500;
    border: 1px solid #fff;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }

  .closing-cta:hover {
    transform: translateY(-3px);
    box-shadow: 0 0 22px rgba(136, 216, 255, 0.4);
  }

  @media (max-width: 48rem) {
    .content-page {
      padding-top: 5.5rem;
      padding-left: 1rem;
      padding-right: 1rem;
    }

    .page-header,
    .cases-list,
    .closing {
      grid-column: 1 / -1;
    }

    .page-header {
      margin-bottom: 2.5rem;
      padding-bottom: 2rem;
    }

    .case-card {
      padding: 1.75rem 1.4rem;
    }

    .closing {
      padding: 3rem 1rem;
      margin-top: 3rem;
    }
  }

</style>
