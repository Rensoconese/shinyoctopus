---
import Layout from "../../layouts/Layout.astro";
import { getCollection, render } from "astro:content";

export async function getStaticPaths() {
  const posts = await getCollection("blog", ({ data }) => {
    return import.meta.env.PROD ? data.draft !== true : true;
  });

  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

// Fetch all published posts for related posts section
const allPosts = await getCollection("blog", ({ data }) => {
  return data.draft !== true;
});

const currentTags = post.data.tags || [];
const otherPosts = allPosts
  .filter((p) => p.id !== post.id)
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());

// Find posts sharing at least one tag
let relatedPosts = currentTags.length > 0
  ? otherPosts.filter((p) => {
      const pTags = p.data.tags || [];
      return pTags.some((t: string) => currentTags.includes(t));
    })
  : [];

// Fall back to most recent posts if no tag matches
if (relatedPosts.length === 0) {
  relatedPosts = otherPosts;
}

relatedPosts = relatedPosts.slice(0, 3);

// Determine CTA link based on tags
const hasAccessibilityTag = currentTags.some(
  (t: string) => t.toLowerCase() === "accessibility" || t.toLowerCase() === "accesibilidad"
);
const ctaServiceLink = hasAccessibilityTag ? "/accesibilidad" : "/seo";
const ctaServiceLabel = hasAccessibilityTag ? "Accessibility services" : "SEO services";

// Reading time estimate: ~200 words per minute
const wordCount = post.body ? post.body.split(/\s+/).length : 0;
const readingTime = Math.max(1, Math.ceil(wordCount / 200));

const formattedDate = post.data.pubDate.toLocaleDateString("en-US", {
  year: "numeric",
  month: "long",
  day: "numeric",
});

const updatedDate = post.data.updatedDate || post.data.pubDate;
const formattedUpdatedDate = updatedDate.toLocaleDateString("en-US", {
  year: "numeric",
  month: "long",
  day: "numeric",
});

// Extract FAQ pairs from raw markdown body
function extractFaqPairs(body: string): Array<{ question: string; answer: string }> {
  if (!body) return [];

  const lines = body.split('\n');
  const pairs: Array<{ question: string; answer: string }> = [];
  let inFaqSection = false;
  let currentQuestion = '';
  let currentAnswer: string[] = [];

  for (const line of lines) {
    // Detect FAQ section start (## heading containing "frequently asked questions")
    if (/^##\s+/i.test(line) && /frequently\s+asked\s+questions/i.test(line)) {
      inFaqSection = true;
      continue;
    }

    // A new H2 ends the FAQ section
    if (inFaqSection && /^##\s+/.test(line) && !/^###/.test(line)) {
      // Save any pending Q&A
      if (currentQuestion && currentAnswer.length) {
        pairs.push({ question: currentQuestion, answer: cleanMarkdown(currentAnswer.join(' ').trim()) });
      }
      break;
    }

    if (!inFaqSection) continue;

    // H3 = new question
    if (/^###\s+/.test(line)) {
      // Save previous Q&A pair
      if (currentQuestion && currentAnswer.length) {
        pairs.push({ question: currentQuestion, answer: cleanMarkdown(currentAnswer.join(' ').trim()) });
      }
      currentQuestion = line.replace(/^###\s+/, '').trim();
      currentAnswer = [];
      continue;
    }

    // Accumulate answer text (skip empty lines and non-paragraph content)
    if (currentQuestion) {
      const trimmed = line.trim();
      if (trimmed) {
        currentAnswer.push(trimmed);
      }
    }
  }

  // Save last Q&A pair
  if (currentQuestion && currentAnswer.length) {
    pairs.push({ question: currentQuestion, answer: cleanMarkdown(currentAnswer.join(' ').trim()) });
  }

  return pairs;
}

// Strip markdown formatting from text
function cleanMarkdown(text: string): string {
  return text
    .replace(/\[([^\]]+)\]\([^)]+\)/g, '$1')   // [link text](url) → link text
    .replace(/\*\*([^*]+)\*\*/g, '$1')           // **bold** → bold
    .replace(/\*([^*]+)\*/g, '$1')               // *italic* → italic
    .replace(/`([^`]+)`/g, '$1')                 // `code` → code
    .replace(/^[-*]\s+/gm, '')                   // list markers
    .replace(/\s+/g, ' ')                        // normalize whitespace
    .trim();
}

const faqPairs = extractFaqPairs(post.body || '');

const faqSchema = faqPairs.length > 0 ? {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqPairs.map(({ question, answer }) => ({
    "@type": "Question",
    "name": question,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": answer
    }
  }))
} : null;

const articleSchema = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": post.data.title,
  "description": post.data.description,
  "datePublished": post.data.pubDate.toISOString(),
  "dateModified": updatedDate.toISOString(),
  "wordCount": wordCount,
  "author": {
    "@type": "Organization",
    "name": "Shiny Octopus",
    "url": "https://shinyoctopus.studio"
  },
  "publisher": {
    "@type": "Organization",
    "name": "Shiny Octopus",
    "logo": {
      "@type": "ImageObject",
      "url": "https://shinyoctopus.studio/images/og-image.jpg"
    }
  },
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": `https://shinyoctopus.studio/blog/${post.id}`
  },
  ...(post.data.tags && { "keywords": post.data.tags.join(", ") })
};
---

<Layout title={`${post.data.title} | Shiny Octopus`} description={post.data.description} type="article" schema={[articleSchema, ...(faqSchema ? [faqSchema] : [])]}>
  <main id="main-content" class="content-page">
    <a href="/blog" class="back-link">&larr; Back to blog</a>

    <article class="post">
      <header class="post-header">
        <div class="post-meta">
          <time datetime={post.data.pubDate.toISOString()}>{formattedDate}</time>
          {post.data.updatedDate && (
            <>
              <span class="separator">&middot;</span>
              <span>Updated <time datetime={updatedDate.toISOString()}>{formattedUpdatedDate}</time></span>
            </>
          )}
          <span class="separator">&middot;</span>
          <span>{readingTime} min read</span>
        </div>
        <h1>{post.data.title}</h1>
        <p class="post-description">{post.data.description}</p>
        {post.data.tags && (
          <ul class="tags">
            {post.data.tags.map((tag: string) => (
              <li>{tag}</li>
            ))}
          </ul>
        )}
      </header>

      <div class="prose">
        <Content />
      </div>
    </article>

    {relatedPosts.length > 0 && (
      <section aria-label="Related posts" class="related-posts">
        <h2>Related posts</h2>
        <div class="related-grid">
          {relatedPosts.map((rp) => {
            const rpDate = rp.data.pubDate.toLocaleDateString("en-US", {
              year: "numeric",
              month: "long",
              day: "numeric",
            });
            const desc = rp.data.description.length > 120
              ? rp.data.description.slice(0, 120).trimEnd() + "..."
              : rp.data.description;
            return (
              <article class="related-card">
                <a href={`/blog/${rp.id}`} class="related-card-link">
                  <time datetime={rp.data.pubDate.toISOString()}>{rpDate}</time>
                  <h3>{rp.data.title}</h3>
                  <p>{desc}</p>
                </a>
              </article>
            );
          })}
        </div>
      </section>
    )}

    <section class="cta-section" aria-label="Call to action">
      <h2>Ready to improve your website?</h2>
      <p>We help businesses build faster, more accessible, and search-optimized websites. Let's talk about what we can do for yours.</p>
      <div class="cta-links">
        <a href={ctaServiceLink} class="cta-btn cta-btn--primary">{ctaServiceLabel}</a>
        <a href="/contact" class="cta-btn cta-btn--secondary">Get in touch</a>
      </div>
    </section>
  </main>
</Layout>

<script is:inline>
  document.querySelectorAll('.prose table').forEach(table => {
    const headers = Array.from(table.querySelectorAll('thead th')).map(th => th.textContent.trim());
    if (!headers.length) return;
    table.querySelectorAll('tbody tr').forEach(tr => {
      tr.querySelectorAll('td').forEach((td, i) => {
        if (headers[i]) td.setAttribute('data-label', headers[i]);
      });
    });
  });
</script>

<style>
  .content-page {
    width: min(100%, 70rem);
    min-width: 0;
    margin: 0 auto;
    padding: 6.5rem 1rem 4rem;
  }

  .back-link {
    display: inline-block;
    font-size: 0.82rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: rgba(255, 255, 255, 0.5);
    text-decoration: none;
    margin-bottom: 2.5rem;
    transition: color 0.2s ease;
  }

  .back-link:hover {
    color: #fff;
  }

  .post-header {
    margin-bottom: 3rem;
    padding-bottom: 2.5rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.12);
  }

  .post-meta {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.78rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: rgba(255, 255, 255, 0.45);
    margin-bottom: 1rem;
  }

  .separator {
    opacity: 0.4;
  }

  h1 {
    font-family: var(--font-titles);
    font-size: clamp(2rem, 5.5vw, 3.5rem);
    line-height: 1;
    font-weight: 100;
    text-transform: uppercase;
    margin-bottom: 1.2rem;
    max-width: 44rem;
  }

  .post-description {
    font-size: 1.1rem;
    color: rgba(255, 255, 255, 0.7);
    max-width: 40rem;
    line-height: 1.55;
  }

  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    list-style: none;
    padding: 0;
    margin-top: 1.2rem;
  }

  .tags li {
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: rgba(255, 255, 255, 0.5);
    border: 1px solid rgba(255, 255, 255, 0.15);
    border-radius: 999px;
    padding: 0.2rem 0.55rem;
  }

  .prose {
    max-width: 44rem;
  }

  .prose :global(h2) {
    font-size: clamp(1.3rem, 3vw, 1.9rem);
    font-weight: 500;
    margin-top: 2.5rem;
    margin-bottom: 0.8rem;
    color: #fff;
  }

  .prose :global(h3) {
    font-size: 1.15rem;
    font-weight: 500;
    margin-top: 2rem;
    margin-bottom: 0.6rem;
    color: #fff;
  }

  .prose :global(p) {
    line-height: 1.7;
    color: rgba(255, 255, 255, 0.85);
    margin-bottom: 1.25rem;
    font-size: 1.02rem;
  }

  .prose :global(ul),
  .prose :global(ol) {
    padding-left: 1.2rem;
    margin-bottom: 1.25rem;
    display: grid;
    gap: 0.5rem;
  }

  .prose :global(li) {
    line-height: 1.6;
    color: rgba(255, 255, 255, 0.85);
  }

  .prose :global(a) {
    color: #fff;
    text-decoration: underline;
    text-underline-offset: 0.15em;
    transition: opacity 0.2s ease;
  }

  .prose :global(a:hover) {
    opacity: 0.7;
  }

  .prose :global(blockquote) {
    border-left: 2px solid rgba(255, 255, 255, 0.2);
    padding-left: 1.25rem;
    margin: 1.5rem 0;
    color: rgba(255, 255, 255, 0.65);
    font-style: italic;
  }

  .prose :global(code) {
    font-size: 0.9em;
    background: rgba(255, 255, 255, 0.08);
    padding: 0.15em 0.35em;
    border-radius: 0.25rem;
  }

  .prose :global(pre) {
    background: rgba(255, 255, 255, 0.06);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 0.5rem;
    padding: 1.25rem;
    overflow-x: auto;
    margin-bottom: 1.5rem;
  }

  .prose :global(pre code) {
    background: none;
    padding: 0;
  }

  .prose :global(hr) {
    border: none;
    border-top: 1px solid rgba(255, 255, 255, 0.12);
    margin: 2.5rem 0;
  }

  .prose :global(img) {
    max-width: 100%;
    height: auto;
    border-radius: 0.5rem;
    margin: 1.5rem 0;
  }

  .prose :global(strong) {
    color: #fff;
    font-weight: 600;
  }

  .prose :global(table) {
    width: 100%;
    border-collapse: collapse;
    margin-bottom: 1.5rem;
  }

  .prose :global(th),
  .prose :global(td) {
    text-align: left;
    vertical-align: top;
    padding: 0.75rem 1rem 0.75rem 0;
    border-bottom: 1px solid rgba(255, 255, 255, 0.12);
    line-height: 1.55;
    color: rgba(255, 255, 255, 0.9);
  }

  .prose :global(thead th) {
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: rgba(255, 255, 255, 0.45);
    border-bottom-color: rgba(255, 255, 255, 0.15);
  }

  /* Related posts */
  .related-posts {
    margin-top: 4rem;
    padding-top: 3rem;
    border-top: 1px solid rgba(255, 255, 255, 0.12);
  }

  .related-posts h2 {
    font-family: var(--font-titles);
    font-size: clamp(1.3rem, 3vw, 1.9rem);
    font-weight: 100;
    text-transform: uppercase;
    margin-bottom: 1.5rem;
  }

  .related-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
  }

  .related-card {
    border: 1px solid rgba(255, 255, 255, 0.12);
    border-radius: 0.5rem;
    transition: border-color 0.2s ease, background 0.2s ease;
  }

  .related-card:hover {
    border-color: rgba(255, 255, 255, 0.3);
    background: rgba(255, 255, 255, 0.04);
  }

  .related-card-link {
    display: block;
    padding: 1.25rem;
    text-decoration: none;
    color: inherit;
  }

  .related-card-link:focus-visible {
    outline: 2px solid rgba(255, 255, 255, 0.6);
    outline-offset: 2px;
    border-radius: 0.5rem;
  }

  .related-card-link time {
    display: block;
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: rgba(255, 255, 255, 0.4);
    margin-bottom: 0.5rem;
  }

  .related-card-link h3 {
    font-size: 1.05rem;
    font-weight: 500;
    color: #fff;
    margin-bottom: 0.4rem;
    line-height: 1.35;
  }

  .related-card-link p {
    font-size: 0.88rem;
    color: rgba(255, 255, 255, 0.6);
    line-height: 1.5;
    margin: 0;
  }

  /* CTA section */
  .cta-section {
    margin-top: 3.5rem;
    padding-top: 3rem;
    border-top: 1px solid rgba(255, 255, 255, 0.12);
    text-align: center;
    padding-bottom: 2rem;
  }

  .cta-section h2 {
    font-family: var(--font-titles);
    font-size: clamp(1.3rem, 3vw, 1.9rem);
    font-weight: 100;
    text-transform: uppercase;
    margin-bottom: 0.8rem;
  }

  .cta-section p {
    font-size: 1rem;
    color: rgba(255, 255, 255, 0.7);
    line-height: 1.6;
    max-width: 32rem;
    margin: 0 auto 1.5rem;
  }

  .cta-links {
    display: flex;
    justify-content: center;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  .cta-btn {
    display: inline-block;
    font-size: 0.82rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    text-decoration: none;
    padding: 0.6rem 1.4rem;
    border-radius: 999px;
    transition: background 0.2s ease, color 0.2s ease, border-color 0.2s ease;
  }

  .cta-btn:focus-visible {
    outline: 2px solid rgba(255, 255, 255, 0.6);
    outline-offset: 2px;
  }

  .cta-btn--primary {
    background: #fff;
    color: #000;
    border: 1px solid #fff;
  }

  .cta-btn--primary:hover {
    background: rgba(255, 255, 255, 0.85);
  }

  .cta-btn--secondary {
    background: transparent;
    color: rgba(255, 255, 255, 0.8);
    border: 1px solid rgba(255, 255, 255, 0.25);
  }

  .cta-btn--secondary:hover {
    border-color: rgba(255, 255, 255, 0.5);
    color: #fff;
  }

  @media (min-width: 48rem) {
    .related-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  @media (max-width: 48rem) {
    .content-page {
      padding-top: 5.5rem;
    }

    .post-header {
      margin-bottom: 2rem;
      padding-bottom: 1.5rem;
    }

    .prose :global(table) {
      display: block;
      overflow-x: auto;
      -webkit-overflow-scrolling: touch;
    }

    .prose :global(thead) {
      display: none;
    }

    .prose :global(tbody) {
      display: block;
    }

    .prose :global(tr) {
      display: block;
      padding: 1.25rem 0;
      border-bottom: 1px solid rgba(255, 255, 255, 0.12);
    }

    .prose :global(td) {
      display: block;
      padding: 0.25rem 0;
      border-bottom: none;
    }

    .prose :global(td::before) {
      content: attr(data-label);
      display: block;
      font-size: 0.75rem;
      text-transform: uppercase;
      letter-spacing: 0.06em;
      color: rgba(255, 255, 255, 0.45);
      margin-bottom: 0.15rem;
    }
  }
</style>
