---
// Importar el componente Image de Astro para optimización de imágenes
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";

// Definir la interfaz para las propiedades del componente
interface Props {
    title: string;
    images: (ImageMetadata | string)[];
    websiteUrl?: string;
    caseStudyHref?: string;
    backgroundImage: ImageMetadata | string;
    backgroundSmall?: boolean;
    testimonial: {
        text: string;
        name: string;
        position: string;
    };
}

// Extraer propiedades del objeto Astro.props
const { title, images, backgroundImage, backgroundSmall, testimonial, websiteUrl, caseStudyHref } = Astro.props;
---

<section class="project-showcase">
    <div class={`background-container${backgroundSmall ? ' background-container-small' : ''}`}>
        {typeof backgroundImage === 'string' ? (
            <img
                src={backgroundImage}
                alt={`${title} background`}
                class={`background-image${backgroundSmall ? ' background-small' : ''}`}
            />
        ) : (
            <Image
                src={backgroundImage}
                alt={`${title} background`}
                width={1920}
                height={1080}
                quality={80}
                class={`background-image${backgroundSmall ? ' background-small' : ''}`}
            />
        )}
    </div>
    <div class="showcase-container">
        <!-- Primera columna: año, título y imágenes -->
        <div class="column column-left">
            <div class="project-info">
                <h3 class="title">{title}</h3>
            </div>
            <div class="project-container-link">
                {(websiteUrl || caseStudyHref) && (
                    <div class="website-link">
                        {caseStudyHref && (
                            <a class="case-study-link" href={caseStudyHref}>Read case study</a>
                        )}
                        {websiteUrl && (
                            <a href={websiteUrl} target="_blank" rel="noopener noreferrer">Visit website</a>
                        )}
                    </div>
                )}
            </div>  
        </div>

        <!-- Segunda columna: testimonio -->
        <div class="column column-middle">
            <div class="testimonial">
                <p>"{testimonial.text}"</p>
                <div class="testimonial-author">
                    <span class="name">{testimonial.name}</span>
                    <span class="position">{testimonial.position}</span>
                </div>
            </div>
        </div>
    </div>
</section>

<style>
   
   .project-showcase {
        position: relative;
        color: #fff;
        height: 100%;
        border-bottom: 1px solid #202020;
        border-top: 1px solid #202020;
    }
    .background-container {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
    }
    
    .background-image {
        width: 100%;
        height: 100%;
        object-fit: contain;
        object-position: center top;
        display: block;
    }

    .showcase-container {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        grid-template-rows: 38rem;
        position: relative;
       
    }

    



    /* Primera columna */
    .column-left {
        display: flex;
        flex-direction: column;
        justify-content: space-between;
        grid-column: 1 / 4;
        padding: 2.5rem;
    }

    .title {
        font-family: var(--font-titles);
        font-weight: 100;
        font-size: clamp(3rem, 6vw, 5rem);
        text-transform: uppercase;
        line-height: 0.9;
        margin: 0;
        letter-spacing: -0.02em;
        max-width: 32rem;
    }

    .project-container-link {
        display: grid;
        gap: 1rem;
    }

    /* Segunda columna */
    .column-middle {
        grid-column: 4 / 5;
        padding: 2.5rem 2.5rem 2.5rem 0;
    }

    .testimonial {
        height: 100%;
    }

    .background-container-small {
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .background-small {
        object-fit: contain;
        width: 55%;
        height: 80%;
        opacity: 0.8;
    }

    .testimonial p {
        font-family: "PP Neue Montreal", sans-serif;
        font-weight: 400;
        line-height: 1.2lh;
        max-width: 30rem;
        margin-bottom: 1.5rem;
    }

    .testimonial-author {
        display: grid;
        gap: 0.25rem;
    }

    .name {
        font-weight: 700;
    }

    .position {
        font-size: 0.8rem;
        color: rgba(255, 255, 255, 0.8);
    }
    
    .website-link {
        display: flex;
        flex-wrap: wrap;
        align-items: center;
        gap: 1rem 1.5rem;
    }

    .website-link a {
        font-size: 0.8rem;
        color: rgba(255, 255, 255, 0.8);
        text-decoration: none;
        transition: color 0.2s ease;
    }

    .website-link a:hover {
        color: #fff;
        text-decoration: underline;
    }

    .website-link .case-study-link {
        color: #fff;
        font-weight: 500;
        border-bottom: 1px solid rgba(255, 255, 255, 0.6);
        padding-bottom: 0.1rem;
    }

    .website-link .case-study-link:hover {
        text-decoration: none;
        border-color: #88d8ff;
        color: #88d8ff;
    }

    @media (max-width: 75rem) {
        .showcase-container {
            grid-template-columns: 1fr;
            grid-template-rows: auto;
            height: auto;
            min-height: auto;
        }

        .column-left {
            grid-column: 1 / 7;
            padding: 2rem;
        }
        
        .column-middle {
            max-width: 100%;
            padding: 2rem;
            margin: 0;
            grid-column: 1/7;
        }

        .testimonial {
            max-width: 30rem;
        }

    }

    @media (max-width: 30rem) {
        .project-showcase {
            margin-top: 2rem;
            padding-top: 2rem;
        }
        
        .showcase-container {
            grid-template-rows: auto;
        }
        
        .column-left {
            padding: 2rem 2rem 1rem;
        }
        
    }
</style>
