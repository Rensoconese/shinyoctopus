---
---

<div class="lead-magnet">
    <h3 class="lead-magnet-title">Enter your URL and we'll send you 3 things to fix — free.</h3>
    <form class="lead-magnet-form" action="/contact" method="POST">
        <div class="lead-magnet-fields">
            <label for="lead-magnet-url" class="sr-only">Website URL</label>
            <input
                type="url"
                name="url"
                id="lead-magnet-url"
                placeholder="https://yourwebsite.com"
                required
                class="lead-magnet-input"
            />
            <label for="lead-magnet-email" class="sr-only">Email address</label>
            <input
                type="email"
                name="email"
                id="lead-magnet-email"
                placeholder="your@email.com"
                required
                class="lead-magnet-input"
            />
        </div>
        <button type="submit" class="lead-magnet-button">Send me my free audit</button>
    </form>
</div>

<style>
    .lead-magnet {
        max-width: 40rem;
        width: 100%;
        margin: 0 auto;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 1.5rem;
    }

    .lead-magnet-title {
        font-family: var(--font-titles);
        font-weight: 100;
        font-size: clamp(1.1rem, 2vw, 1.35rem);
        text-transform: uppercase;
        text-align: center;
        opacity: 0.85;
        line-height: 1.3;
    }

    .lead-magnet-form {
        width: 100%;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 1rem;
    }

    .lead-magnet-fields {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 0.75rem;
        width: 100%;
    }

    .lead-magnet-input {
        background: rgba(255, 255, 255, 0.06);
        border: 1px solid rgba(255, 255, 255, 0.12);
        border-radius: 0.75rem;
        padding: 0.85rem 1rem;
        color: white;
        font-size: 0.95rem;
        font-family: inherit;
        transition: border-color 0.3s ease;
        width: 100%;
        box-sizing: border-box;
    }

    .lead-magnet-input::placeholder {
        color: rgba(255, 255, 255, 0.35);
    }

    .lead-magnet-input:focus-visible {
        border-color: rgba(var(--color-glow-rgb), 0.6);
        outline: 2px solid rgba(var(--color-glow-rgb), 0.8);
        outline-offset: 2px;
    }

    .lead-magnet-button {
        background: white;
        color: black;
        border: 1px solid white;
        border-radius: 1.5rem;
        padding: 0.85rem 1.5rem;
        font-size: 1rem;
        font-family: inherit;
        cursor: pointer;
        transition:
            background-color 0.3s ease,
            border-color 0.3s ease,
            transform 0.3s ease,
            box-shadow 0.3s ease;
    }

    .lead-magnet-button:hover {
        background-color: black;
        color: white;
        border-color: rgba(255, 255, 255, 0.5);
        transform: translateY(-3px);
        box-shadow:
            0 0 10px #fff,
            0 0 20px var(--color-glow),
            0 0 30px var(--color-glow),
            0 0 40px var(--color-glow-blue),
            0 0 70px var(--color-glow-blue);
    }

    .lead-magnet-button:active {
        background-color: #555;
    }

    .lead-magnet-button:focus-visible {
        outline: 2px solid #fff;
        outline-offset: 3px;
    }

    .sr-only {
        position: absolute;
        width: 1px;
        height: 1px;
        padding: 0;
        margin: -1px;
        overflow: hidden;
        clip: rect(0,0,0,0);
        white-space: nowrap;
        border: 0;
    }

    @media (max-width: 768px) {
        .lead-magnet-fields {
            grid-template-columns: 1fr;
        }
    }

    @media (prefers-reduced-motion: reduce) {
        .lead-magnet-button:hover { transform: none; }
    }
</style>
