---
---

<section class="stats">
    <div class="stats-container">
        <div class="stat">
            <span class="stat-number">50+</span>
            <span class="stat-label">websites built & audited</span>
        </div>
        <div class="stat">
            <span class="stat-number">8+</span>
            <span class="stat-label">years on the web</span>
        </div>
        <div class="stat">
            <span class="stat-number">3</span>
            <span class="stat-label">countries served</span>
        </div>
    </div>
</section>

<style>
    .stats {
        background: #000;
        color: #fff;
        padding: 6rem 2rem;
    }

    .stats-container {
        max-width: 70rem;
        margin: 0 auto;
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 2rem;
    }

    .stat {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 0.75rem;
        flex: 1;
    }

    .stat-number {
        font-family: var(--font-titles);
        font-weight: 100;
        font-size: clamp(3.5rem, 8vw, 6rem);
        line-height: 1;
        text-shadow: 0 0 10px rgba(136, 216, 255, 0.4), 0 0 30px rgba(136, 216, 255, 0.2);
    }

    .stat-label {
        font-family: var(--font-body);
        font-size: clamp(1rem, 1.5vw, 1.125rem);
        opacity: 0.7;
        text-align: center;
        text-transform: lowercase;
    }

    @media (max-width: 768px) {
        .stats {
            padding: 4rem 2rem;
        }

        .stats-container {
            flex-direction: column;
            gap: 3rem;
        }
    }
</style>
