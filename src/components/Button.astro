---
interface Props {
    text: string;
    href?: string;
}

const { text, href } = Astro.props;
---

{href ? (
    <a href={href} class="custom-button">
        {text}
    </a>
) : (
    <button type="button" class="custom-button">
        {text}
    </button>
)}

<style>
    .custom-button {
        background-color: white;
        color: black;
        border: 1px solid rgb(255, 255, 255);
        border-radius: 1.5rem;
        padding: 1rem 1.2rem;
        cursor: pointer;
        font-size: 1.2rem;
        transition:
            background-color 0.3s ease,
            border-color 0.3s ease,
            transform 0.3s ease,
            box-shadow 0.3s ease;
        display: inline-block;
        text-decoration: none;
        position: relative;
    }

    .custom-button:hover {
        background-color: black;
        color: white;
        border-color: rgba(255, 255, 255, 0.5);
        transform: translateY(-5px);
        box-shadow:
            0 0 10px #fff,
            0 0 20px var(--color-glow),
            0 0 30px var(--color-glow),
            0 0 40px var(--color-glow-blue),
            0 0 70px var(--color-glow-blue),
            0 0 80px var(--color-glow-deep),
            0 0 100px var(--color-glow-deeper),
            0 0 150px var(--color-glow-deepest);
    }

    .custom-button:active {
        background-color: #555;
    }

    .custom-button:focus-visible {
        outline: 2px solid #fff;
        outline-offset: 3px;
    }

    @media (prefers-reduced-motion: reduce) {
        .custom-button:hover { transform: none; }
    }
</style>
